[Unit]
Description=Wi‑Fi Failover Monitor for Victron BLE to MQTT
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Restart=always
RestartSec=5
Environment=HOME=/home/%i
WorkingDirectory=/home/%i/victron-ble2mqtt-integration
ExecStart=/usr/bin/env bash scripts/monitor_failover.sh

[Install]
WantedBy=multi-user.target
