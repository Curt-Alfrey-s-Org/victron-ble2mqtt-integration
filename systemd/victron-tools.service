[Unit]
Description=Victron tools compose (Dozzle + Portainer + Watchtower)
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/n4s1/victron-ble2mqtt-integration
ExecStart=/usr/bin/docker compose -f docker-compose.tools.yml up -d
ExecStop=/usr/bin/docker compose -f docker-compose.tools.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
