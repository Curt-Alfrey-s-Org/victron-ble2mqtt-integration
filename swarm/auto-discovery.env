# Broker details are inherited from ha-discovery.env/health.env at deploy time.
# This file only declares topic root + naming.
TOPIC_ROOT=victron
DEVICE_NAME_PREFIX=Victron
# Optional: limit to specific devices (comma-separated IDs) -> e.g. LIMIT_DEVICES=mppt1,shuntA
# LIMIT_DEVICES=

LIMIT_DEVICES=Battery 1,Battery 2,BlueSolar,SmartShunt-KU,SmartShunt-T2,Solar-controller
